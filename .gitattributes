# Binary robot mesh assets — Git LFS
*.stl filter=lfs diff=lfs merge=lfs -text
*.dae filter=lfs diff=lfs merge=lfs -text

# Source code — LF line endings
*.cpp        text eol=lf
*.hpp        text eol=lf
*.h          text eol=lf
*.ino        text eol=lf
*.py         text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.xml        text eol=lf
*.xacro      text eol=lf
*.launch.py  text eol=lf
*.msg        text eol=lf
*.srv        text eol=lf
*.action     text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.cfg        text eol=lf
*.cmake      text eol=lf
CMakeLists.txt text eol=lf
package.xml  text eol=lf

# Generated / binary — no useful diff
*.onnx       -diff
*.png        -diff
*.jpg        -diff
*.pgm        -diff
*.pdf        -diff
