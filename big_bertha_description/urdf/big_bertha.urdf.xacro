      <inertia ixx="6.165745856353591e-05" iyy="5.834254143646408e-05" izz="4.198895027624309e-05" ixy="-6.629834254143645e-06" iyz="2.209944751381215e-07" ixz="-2.2099447513812153e-06"/>
    </inertial>
    <visual>
      <origin xyz="-0.0802 -0.0649 -0.0278" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/arm_a_2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.0802 -0.0649 -0.0278" rpy="0 0 0"/>
