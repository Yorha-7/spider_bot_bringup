        <mesh filename="${mesh_pkg}/arm_b_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="arm_c_4_1">
    <inertial>
      <origin xyz="-0.04092049433517593 0.000606221473381241 -0.0346865874039218" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00020097902097902098" iyy="0.00020377622377622378" izz="8.685314685314686e-05" ixy="-3.132867132867133e-05" iyz="-7.272727272727273e-05" ixz="-6.979020979020979e-05"/>
    </inertial>
    <visual>
      <origin xyz="0.124465 0.14848 -0.082982" rpy="0 0 0"/>
      <geometry>
