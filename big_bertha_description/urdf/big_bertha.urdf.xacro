  <!-- ============================== Joints ============================= -->
  <!-- Leg 4 (back-left): Revolute_110/111/112 -->
  <joint name="Revolute_110" type="continuous">
    <origin xyz="-0.0802 -0.0649 0.0278" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="arm_a_4_1"/>
    <axis xyz="0.0 -0.0 1.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_111" type="continuous">
    <origin xyz="-0.015981 -0.055296 -0.0141" rpy="0 0 0"/>
    <parent link="arm_a_4_1"/>
    <child link="arm_b_4_1"/>
    <axis xyz="0.707107 -0.707107 0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_112" type="continuous">
    <origin xyz="-0.028284 -0.028284 0.069282" rpy="0 0 0"/>
    <parent link="arm_b_4_1"/>
    <child link="arm_c_4_1"/>
    <axis xyz="-0.707107 0.707107 -0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Leg 1 (front-left): Revolute_113/114/115 -->
  <joint name="Revolute_113" type="continuous">
    <origin xyz="0.0802 -0.0649 0.0278" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="arm_a_1_1"/>
    <axis xyz="0.0 -0.0 1.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_114" type="continuous">
    <origin xyz="0.055296 -0.015981 -0.0141" rpy="0 0 0"/>
    <parent link="arm_a_1_1"/>
    <child link="arm_b_1_1"/>
    <axis xyz="0.707107 0.707107 0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_115" type="continuous">
    <origin xyz="0.028284 -0.028284 0.069282" rpy="0 0 0"/>
    <parent link="arm_b_1_1"/>
    <child link="arm_c_1_1"/>
    <axis xyz="-0.707107 -0.707107 -0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Leg 2 (front-right): Revolute_116/117/118 -->
  <joint name="Revolute_116" type="continuous">
    <origin xyz="0.0802 0.0649 0.0278" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="arm_a_2_1"/>
    <axis xyz="-0.0 0.0 1.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_117" type="continuous">
    <origin xyz="0.015981 0.055296 -0.0141" rpy="0 0 0"/>
    <parent link="arm_a_2_1"/>
    <child link="arm_b_2_1"/>
    <axis xyz="-0.707107 0.707107 -0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_118" type="continuous">
    <origin xyz="0.028284 0.028284 0.069282" rpy="0 0 0"/>
    <parent link="arm_b_2_1"/>
    <child link="arm_c_2_1"/>
    <axis xyz="0.707107 -0.707107 -0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Leg 3 (back-right): Revolute_119/120/121 -->
  <joint name="Revolute_119" type="continuous">
    <origin xyz="-0.0802 0.0649 0.0278" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="arm_a_3_1"/>
    <axis xyz="-0.0 0.0 1.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_120" type="continuous">
    <origin xyz="-0.055296 0.015981 -0.0141" rpy="0 0 0"/>
    <parent link="arm_a_3_1"/>
    <child link="arm_b_3_1"/>
    <axis xyz="-0.707107 -0.707107 0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="Revolute_121" type="continuous">
    <origin xyz="-0.028284 0.028284 0.069282" rpy="0 0 0"/>
    <parent link="arm_b_3_1"/>
    <child link="arm_c_3_1"/>
    <axis xyz="0.707107 0.707107 -0.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Fixed sensor / payload frames -->
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.01 0.01 0.041" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
  </joint>

  <joint name="battery_joint" type="fixed">
    <origin xyz="-0.04450 0.015 0.0065" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="battery_link"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0.0 0.0 0.01" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>

  <!-- =================== ros2_control + Gazebo plugins ================= -->
  <xacro:if value="${use_gz}">
    <xacro:include filename="$(find big_bertha_description)/urdf/big_bertha.ros2_control.xacro"/>
    <xacro:include filename="$(find big_bertha_description)/urdf/big_bertha.gazebo.xacro"/>
  </xacro:if>

</robot>
