      <origin xyz="0.04092049563456594 -0.0006062201740217599 -0.034686586023032526" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00020097902097902098" iyy="0.00020377622377622378" izz="8.685314685314686e-05" ixy="-3.132867132867133e-05" iyz="7.272727272727273e-05" ixz="6.979020979020979e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.124465 -0.14848 -0.082982" rpy="0 0 0"/>
      <geometry>
