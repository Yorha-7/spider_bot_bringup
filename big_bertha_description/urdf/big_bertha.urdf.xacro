  </link>

  <link name="arm_b_2_1">
    <inertial>
      <origin xyz="0.033306991137202493 -0.005023373318229579 0.034641011840133185" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="6.934097421203439e-05" iyy="6.934097421203439e-05" izz="6.962750716332379e-05" ixy="2.0916905444126076e-05" iyz="-1.2893982808022926e-05" ixz="-1.2893982808022926e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.096181 -0.120196 -0.0137" rpy="0 0 0"/>
