      <inertia ixx="0.00020377622377622378" iyy="0.00020097902097902098" izz="8.685314685314686e-05" ixy="3.132867132867133e-05" iyz="-6.979020979020979e-05" ixz="7.272727272727273e-05"/>
    </inertial>
    <visual>
